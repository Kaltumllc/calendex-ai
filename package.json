{
  "name": "calendex-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Calendex AI — Intelligent Scheduling Platform",
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --filter ./apps/* run build",
    "start": "pnpm --parallel run start",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
